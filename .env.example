# Permish — Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# Domain (for production HTTPS via Caddy)
# =============================================================================
DOMAIN=permish.app

# =============================================================================
# Backend mode: "express" (default) or "pocketbase"
# =============================================================================
PUBLIC_BACKEND=express

# =============================================================================
# Express Backend
# =============================================================================
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY=24h
# FRONTEND_URL=https://permish.app

# =============================================================================
# Email (SMTP — used by both Express backend and PocketBase sidecar)
# =============================================================================
# EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Permish
EMAIL_FROM_ADDRESS=

# =============================================================================
# PocketBase mode (only needed with PUBLIC_BACKEND=pocketbase)
# =============================================================================
# PB_ADMIN_EMAIL=admin@permish.app
# PB_ADMIN_PASSWORD=

# =============================================================================
# Port overrides (optional — defaults shown)
# =============================================================================
# FRONTEND_PORT=3000
# BACKEND_PORT=3001
# PB_PORT=8090
# SIDECAR_PORT=3002
