{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "process:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "sql:default"
  ]
}
