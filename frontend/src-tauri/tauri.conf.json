{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Permish",
  "version": "0.1.0",
  "identifier": "com.permish.app",
  "build": {
    "beforeBuildCommand": "pnpm build:desktop",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Permish",
        "width": 1024,
        "height": 768,
        "minWidth": 375,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8090 http://127.0.0.1:3002; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/pocketbase",
      "sidecars/node-sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "sidecars/pocketbase",
          "sidecar": true,
          "args": true
        },
        {
          "name": "sidecars/node-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
