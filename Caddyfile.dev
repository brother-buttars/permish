# Local development Caddyfile with HTTPS + hot reload
#
# Usage: ./dev.sh (starts everything automatically)
#
# Access from this machine:  https://dev.permish.app
# Access from mobile/LAN:   https://192.168.3.1
#
# Prerequisites:
#   sudo mkcert -install
#   echo "127.0.0.1 dev.permish.app" | sudo tee -a /etc/hosts

{
	auto_https off
}

https://dev.permish.app, https://192.168.3.1, https://localhost {
	tls certs/dev.pem certs/dev-key.pem

	# Backend API — must come before the frontend catch-all
	handle /api/* {
		reverse_proxy 127.0.0.1:3001
	}

	# SvelteKit dev server (Vite on port 5173)
	# Caddy automatically handles WebSocket upgrades for Vite HMR
	reverse_proxy 127.0.0.1:5173

	encode gzip

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
